---
export const prerender = false;
import Layout from '../layouts/layout.astro';
import AuthModal from '../components/authModal.jsx';

import { supabase } from '../lib/supabase.ts';

const accessToken = Astro.cookies.get('sb-access-token')?.value ?? null;

let user = null;
if (accessToken) {
    const { data, error } = await supabase.auth.getUser(accessToken);
    if (!error) user = data.user;
}
console.log('User:', user);
---

<Layout showAuth={true} user={user}>
    <AuthModal client:load />
    <div class="mt-30 flex flex-1 flex-col items-center justify-start">
        <h1 class="text-5xl font-bold">Catalog Page</h1>
        <p class="mt-4 max-w-xl text-center text-lg">
            This is the catalog page where you can browse all available skins
            for League of Legends.
        </p>
    </div>
</Layout>
